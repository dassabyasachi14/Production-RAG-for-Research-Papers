# Required: Google AI Studio API key (free at https://aistudio.google.com/apikey)
# Used for: Gemini 2.5 Flash (generation + vision) and gemini-embedding-001 (embeddings)
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Optional: Override default storage paths
STORAGE_DIR=storage
BM25_INDEX_PATH=storage/bm25_indexes

# Optional: Prompt version override (default: read from config/prompts/active.yaml)
ACTIVE_PROMPT_VERSION=v1
